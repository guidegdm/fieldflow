# Public site metadata
NEXT_PUBLIC_SITE_URL=https://fieldflow-tau.vercel.app
COGNITO_REDIRECT_URI=https://fieldflow-tau.vercel.app/api/auth/callback

# Runtime mode
# Production should leave this true or omit it. Set false only for local UI work without AWS credentials.
DYNAMODB_ENABLED=true

# AWS runtime credentials for Vercel server routes
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB single-table storage
# Production table schema: pk (String HASH) + sk (String RANGE), PAY_PER_REQUEST, TTL attribute expiresAt.
# Recommended GSIs:
# - gsi1: gsi1pk (String HASH) + gsi1sk (String RANGE) for org-scoped lists and mutation cursors.
# - gsi2: gsi2pk (String HASH) + gsi2sk (String RANGE) for email-to-workspace invite lookup.
DYNAMODB_TABLE=FieldFlowRecords
DYNAMODB_SORT_KEY_ENABLED=true
DYNAMODB_GSI1_NAME=gsi1
DYNAMODB_GSI2_NAME=gsi2
# Set true after the live table is migrated to pk/sk. Current legacy tables can leave this false/unset.
# DYNAMODB_REQUIRE_COMPOSITE_KEY=false
# Set false after old items have been rewritten with gsi1/gsi2 access attributes.
# DYNAMODB_SCAN_FALLBACK_ON_EMPTY_INDEX=true

# S3 attachment uploads
# Browser photos are compressed locally, then uploaded with short-lived presigned PUT URLs.
AWS_S3_BUCKET=
# Optional override if attachments live outside AWS_REGION.
S3_REGION=

# Cognito user pool and hosted UI
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# Required in production for app-owned session and setup cookies. Generate a random 32+ byte secret.
SESSION_SECRET=

# Optional Google OAuth values if configuring Cognito IdP from local scripts.
# The app redirects through Cognito and does not expose the secret client-side.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI workflow assistant
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
