# Public site metadata
NEXT_PUBLIC_SITE_URL=https://fieldflow-tau.vercel.app
COGNITO_REDIRECT_URI=https://fieldflow-tau.vercel.app/api/auth/callback

# Runtime mode
# Production should leave this true or omit it. Set false only for local UI work without AWS credentials.
DYNAMODB_ENABLED=true

# AWS runtime credentials for Vercel server routes
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB single-table storage
# DynamoDB table uses org-scoped pk values and TTL attribute expiresAt.
# Leave DYNAMODB_SORT_KEY_ENABLED unset for runtime schema detection.
# Optional override: true for pk+sk tables, false for pk-only tables.
DYNAMODB_TABLE=FieldFlowRecords
# DYNAMODB_SORT_KEY_ENABLED=true

# S3 attachment uploads
# Browser photos are compressed locally, then uploaded with short-lived presigned PUT URLs.
AWS_S3_BUCKET=
# Optional override if attachments live outside AWS_REGION.
S3_REGION=

# Cognito user pool and hosted UI
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# Cookie/session signing fallback for app-owned demo/session metadata
SESSION_SECRET=

# Optional Google OAuth values if configuring Cognito IdP from local scripts.
# The app redirects through Cognito and does not expose the secret client-side.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI workflow assistant
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=2048
